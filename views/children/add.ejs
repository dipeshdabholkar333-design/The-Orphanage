<%- include('../admin_partials/adminHeader') %>

<div class="container">

<div class="card">

<h2>Add Child</h2>

<form action="/children/add" method="POST">

    <input type="text" name="name" placeholder="Name" required><br><br>

    <input type="number" name="age" placeholder="Age" required><br><br>

    <input type="text" name="gender" placeholder="Gender" required><br><br>

    <input type="date" name="admission_date" required><br><br>

    <input type="text" name="health_status" placeholder="Health Status"><br><br>

    <button type="submit">Save Child</button>

</form>

</div>

</div>

<%- include('../admin_partials/adminFooter') %>