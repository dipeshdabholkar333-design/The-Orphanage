<%- include('../admin_partials/adminHeader') %>

<div class="container">

<div class="card">

<h2>Edit Child</h2>

<form action="/children/update/<%= child.id %>" method="POST">

    <input type="text" name="name" value="<%= child.name %>" required><br><br>

    <input type="number" name="age" value="<%= child.age %>" required><br><br>

    <input type="text" name="gender" value="<%= child.gender %>" required><br><br>

    <input type="date" name="admission_date" value="<%= child.admission_date %>" required><br><br>

    <input type="text" name="health_status" value="<%= child.health_status %>"><br><br>

    <button type="submit">Update Child</button>

</form>

</div>

</div>

<%- include('../admin_partials/adminFooter') %>