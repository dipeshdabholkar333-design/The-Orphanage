<%- include('../admin_partials/adminHeader') %>

<div class="container">

<div class="card">

<h2>Edit Staff</h2>

<form action="/staff/update/<%= staff.id %>" method="POST">

    <input type="text" name="name" value="<%= staff.name %>" required><br><br>

    <input type="text" name="position" value="<%= staff.position %>" required><br><br>

    <input type="number" name="salary" value="<%= staff.salary %>" required><br><br>

    <button type="submit">Update Staff</button>

</form>

</div>

</div>

<%- include('../admin_partials/adminFooter') %>